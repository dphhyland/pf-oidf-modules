# Lighthouse (trust anchor) config-as-code — PRODUCTION. Applied by CI via `railway variables --set`.
# Identical to staging except the entity id (this anchor's own URL). No secrets (signing key on /data).
LH_ENTITY_ID=https://lighthouse-prod-production.up.railway.app
LH_SERVER_PORT=8080
LH_LOG_LEVEL=INFO
LH_STORAGE_DRIVER=sqlite
LH_STORAGE_DATA_DIR=/data
LH_SIGNING_KMS=filesystem
LH_SIGNING_FILESYSTEM_KEY_DIR=/data/keys
LH_ENDPOINTS_FETCH_PATH=/fetch
LH_ENDPOINTS_LIST_PATH=/list
LH_ENDPOINTS_RESOLVE_PATH=/resolve
LH_ENDPOINTS_TRUST_MARK_PATH=/trust_mark
LH_CACHE_DISABLED=true
