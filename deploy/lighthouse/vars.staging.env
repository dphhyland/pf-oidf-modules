# Lighthouse (trust anchor) config-as-code — STAGING. Applied by CI via `railway variables --set`.
# No secrets here (the anchor signing key lives on the /data volume, generated once, never in git).
LH_ENTITY_ID=https://lighthouse-staging-e017.up.railway.app
LH_SERVER_PORT=8080
LH_LOG_LEVEL=INFO
LH_STORAGE_DRIVER=sqlite
LH_STORAGE_DATA_DIR=/data
LH_SIGNING_KMS=filesystem
LH_SIGNING_FILESYSTEM_KEY_DIR=/data/keys
LH_ENDPOINTS_FETCH_PATH=/fetch
LH_ENDPOINTS_LIST_PATH=/list
LH_ENDPOINTS_RESOLVE_PATH=/resolve
LH_ENDPOINTS_TRUST_MARK_PATH=/trust_mark
# Revocation takes effect immediately: no /resolve cache to serve a revoked entity.
LH_CACHE_DISABLED=true
