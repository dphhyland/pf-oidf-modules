# pingfederate-runtime config-as-code — STAGING.
# Non-secret Railway service vars applied by the deploy workflow. Secrets are NEVER here — they are
# GitHub Actions secrets applied to the Railway service (see .github/workflows/deploy-pingfederate.yml).
#
# Licensing: DevOps-fetched (no baked pingfederate.lic). EULA acceptance is non-secret; the DevOps
# credentials (PING_IDENTITY_DEVOPS_USER / PING_IDENTITY_DEVOPS_KEY) are GitHub Actions secrets.
PING_IDENTITY_ACCEPT_EULA=YES
