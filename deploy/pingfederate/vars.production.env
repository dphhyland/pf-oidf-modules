# pingfederate-runtime config-as-code — PRODUCTION.
# Non-secret Railway service vars applied by the deploy workflow. Secrets are NEVER here — they are
# GitHub Actions secrets applied to the Railway service (see .github/workflows/deploy-pingfederate.yml).
#
# Licensing: DevOps-fetched. The image bakes no pingfederate.lic; the base image's boot hook pulls a
# fresh eval license using these vars. EULA acceptance is non-secret; the credentials are secrets:
#   PING_IDENTITY_DEVOPS_USER   <- GitHub secret PING_IDENTITY_DEVOPS_USER (a person's DevOps email)
#   PING_IDENTITY_DEVOPS_KEY    <- GitHub secret PING_IDENTITY_DEVOPS_KEY
PING_IDENTITY_ACCEPT_EULA=YES

# SSF transmitter — env-based config (SsfConfiguration reads OIDF_SSF_<NAME>, or oidf.ssf.<name> from
# run.properties, or a web.xml init-param). Setting OIDF_SSF_ISSUER turns the transmitter on at boot
# (fail-soft: unset = SSF endpoints disabled, never breaks PF). The issuer MUST equal the external base
# receivers use — it's the SET `iss` and the base of jwks_uri (<issuer>/pf/JWKS). With the reassembled war
# the module serves at ROOT, so this is just the PF external base (the runtime TCP proxy).
OIDF_SSF_ISSUER=https://reseau.proxy.rlwy.net:38844
# Optional: OIDF_SSF_RECEIVER_SCOPE (default ssf.manage), OIDF_SSF_DATA_STORE_ID (PF JDBC data store id
# for durable/cluster-safe storage), OIDF_SSF_KAFKA_ENABLED + OIDF_SSF_KAFKA_BOOTSTRAP_SERVERS.
# Receiver auth (stream mgmt/poll/SCIM) validates bearer tokens by PF introspection — set the introspection
# client as SECRETS, never here: OIDF_SSF_INTROSPECTION_CLIENT_ID + OIDF_SSF_INTROSPECTION_CLIENT_SECRET
# (GitHub Actions secrets). The logout → caep.session-revoked signal needs none of that.
