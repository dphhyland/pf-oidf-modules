# pingfederate-runtime config-as-code — PRODUCTION.
# Non-secret Railway service vars applied by the deploy workflow. Secrets are NEVER here — they are
# GitHub Actions secrets applied to the Railway service (see .github/workflows/deploy-pingfederate.yml).
#
# Licensing: DevOps-fetched. The image bakes no pingfederate.lic; the base image's boot hook pulls a
# fresh eval license using these vars. EULA acceptance is non-secret; the credentials are secrets:
#   PING_IDENTITY_DEVOPS_USER   <- GitHub secret PING_IDENTITY_DEVOPS_USER (a person's DevOps email)
#   PING_IDENTITY_DEVOPS_KEY    <- GitHub secret PING_IDENTITY_DEVOPS_KEY
PING_IDENTITY_ACCEPT_EULA=YES
